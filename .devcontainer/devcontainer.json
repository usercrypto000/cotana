{
  "name": "Cotana",
  "dockerComposeFile": [
    "./docker-compose.yml"
  ],
  "service": "app",
  "workspaceFolder": "/workspace",
  "runServices": ["postgres", "redis"],
  "shutdownAction": "stopCompose",
  "postCreateCommand": "npm ci && npx prisma generate",
  "forwardPorts": [3000, 5433, 6379],
  "portsAttributes": {
    "3000": { "label": "Next.js" },
    "5433": { "label": "Postgres" },
    "6379": { "label": "Redis" }
  },
  "remoteEnv": {
    "DATABASE_URL": "postgresql://cotana:cotana@postgres:5432/cotana?schema=public",
    "REDIS_HOST": "redis",
    "REDIS_PORT": "6379"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-azuretools.vscode-docker",
        "ms-vscode-remote.remote-containers",
        "Prisma.prisma"
      ]
    }
  }
}
