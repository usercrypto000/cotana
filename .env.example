# Core runtime
DATABASE_URL="postgresql://cotana:cotana@localhost:5433/cotana?schema=public"
REDIS_URL="redis://localhost:6379"
# Optional alternative to REDIS_URL:
# REDIS_HOST="127.0.0.1"
# REDIS_PORT="6379"
REDIS_FAKE="false"

# Public site metadata
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
PUBLIC_BASE_URL="http://localhost:3000"

# RPC endpoints (required based on EXPLOIT_TRACKER_CHAINS)
ALCHEMY_ETH_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/<KEY>"
ALCHEMY_BASE_RPC_URL="https://base-mainnet.g.alchemy.com/v2/<KEY>"
ALCHEMY_ARB_RPC_URL="https://arb-mainnet.g.alchemy.com/v2/<KEY>"
ALCHEMY_OP_RPC_URL="https://opt-mainnet.g.alchemy.com/v2/<KEY>"

# Optional fallback aliases
RPC_URL_ETH=""
RPC_URL_BASE=""
RPC_URL_ARB=""
RPC_URL_OP=""

# Exploit tracker worker contract
EXPLOIT_TRACKER_CHAINS="1,8453"
EXPLOIT_POLL_BATCH="15"
EXPLOIT_POLL_INTERVAL_MS="5000"
EXPLOIT_MAX_TX_PER_BLOCK="800"
EXPLOIT_DETECT_EVERY_BLOCKS="1"
EXPLOIT_BOOTSTRAP_LOOKBACK_BLOCKS="300"
EXPLOIT_INCIDENT_THRESHOLD="70"
EXPLOIT_ALERT_THRESHOLD="75"
EXPLOIT_RULE_VERSION="v1"
EXPLOIT_CONFIDENCE_DECAY_AFTER_MIN="20"
EXPLOIT_AUTO_RESOLVE_HOURS="6"
EXPLOIT_REPLAY_STEP_MINUTES="10"

# Native asset pricing (optional, improves USD estimates)
NATIVE_PRICE_USD=""
NATIVE_PRICE_USD_1=""
NATIVE_PRICE_USD_8453=""
NATIVE_PRICE_USD_42161=""
NATIVE_PRICE_USD_10=""

# Tenant bootstrap + auth contract
EXPLOIT_DEFAULT_TENANT_SLUG="default"
EXPLOIT_DEFAULT_TENANT_NAME="Default Tenant"
EXPLOIT_DEFAULT_API_KEY="replace-with-long-random-token"
EXPLOIT_JWT_SECRET="replace-with-long-random-secret"

# Tenant runtime policy defaults
EXPLOIT_TRIAL_MODE="false"
EXPLOIT_TRIAL_ALERT_DELAY_SEC="0"
EXPLOIT_PUBLIC_FEED_ENABLED="true"

# Alerts
EXPLOIT_ALERT_WEBHOOK_URL=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Incident websocket server
EXPLOIT_WS_HOST="0.0.0.0"
EXPLOIT_WS_PORT="8099"
EXPLOIT_WS_PUBLIC_HOST="localhost"
EXPLOIT_WS_PUBLIC_SECURE="false"

# Mindshare (kept for existing project paths)
ETHERSCAN_API_KEY=""
BOT_FILTER_THRESHOLD="80"
MINDSHARE_POLL_BATCH="100"
MINDSHARE_POLL_INTERVAL_MS="5000"
MINDSHARE_CHAIN_ID="1"
