# Cotana environment template
# Vercel note:
# Use the same key names below in Vercel for Development, Preview, and Production.
# Vercel does not need separate variable names for dev/live. You assign different values per environment.

# -----------------------------------------------------------------------------
# Core runtime
# Required in all environments
# -----------------------------------------------------------------------------
NODE_ENV="development"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cotana"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/cotana"
REDIS_URL="redis://localhost:6379"
COTANA_SESSION_SECRET="replace-with-a-long-random-string"
ADMIN_ALLOWLIST_EMAIL="admin@cotana.app"

# -----------------------------------------------------------------------------
# Public app URLs
# Required in production
# Development example values are below
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STORE_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"

# Production examples for Vercel:
# NEXT_PUBLIC_STORE_URL="https://cotana-store.vercel.app"
# NEXT_PUBLIC_ADMIN_URL="https://cotana-admin.vercel.app"

# -----------------------------------------------------------------------------
# Privy
# Required for auth
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PRIVY_APP_ID=""
NEXT_PUBLIC_PRIVY_CLIENT_ID=""
PRIVY_APP_ID=""
PRIVY_APP_SECRET=""
PRIVY_VERIFICATION_KEY=""

# -----------------------------------------------------------------------------
# PostHog
# Optional, but recommended for production analytics
# -----------------------------------------------------------------------------
POSTHOG_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# -----------------------------------------------------------------------------
# Inngest
# Required if background jobs/webhooks are enabled
# -----------------------------------------------------------------------------
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# -----------------------------------------------------------------------------
# Embeddings / semantic search
# Current code path:
# Cotana currently expects OPENAI_API_KEY directly.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-large"

# -----------------------------------------------------------------------------
# Signal providers
# Current code path: DeFiLlama plus Covalent/GoldRush readiness.
# Covalent app-level signals require app metadata such as contract addresses or
# protocol identifiers before the provider can produce reliable catalog metrics.
# -----------------------------------------------------------------------------
DEFILLAMA_API_KEY=""

# Picked Covalent APIs for Cotana:
# - DeFi Positions: lending / yield positions and protocol exposure
# - Activity: swap, transfer, and approval activity for engagement signals
# - Transactions: fallback transaction history and volume-style heuristics
# - Token Info: token metadata and pricing enrichment where needed
#
# Not picked right now:
# - Balances: not needed for app discovery
# - Collectibles: not needed for current categories
# - Token Holders: useful later, not required for current ranking loop
# - SVM endpoints: optional later if Cotana expands Solana-specific intelligence
COVALENT_API_KEY=""
COVALENT_BASE_URL="https://api.covalenthq.com/v1"
COVALENT_TIMEOUT_MS="10000"
