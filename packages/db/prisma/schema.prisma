generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum AppStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AppAudience {
  HUMAN
  AGENT
  HYBRID
}

enum AgentListingStatus {
  NOT_APPLICABLE
  DRAFT
  PUBLISHED
  PAUSED
}

enum AgentAuthType {
  NONE
  API_KEY
  OAUTH2
  MCP
  CUSTOM
}

enum AgentInterfaceType {
  HTTP_API
  MCP_SERVER
  SDK
  WEBHOOK
  DATA_FEED
  DOCS_ONLY
}

enum AgentInteractionMode {
  READ_ONLY
  WRITE_ACTION
  TRANSACTIONAL
  HUMAN_HANDOFF
}

enum AgentCapabilityStatus {
  ACTIVE
  PAUSED
  DEPRECATED
}

enum EditorialShelfStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EditorialShelfVisibility {
  HOME
  CATEGORY
  BOTH
}

enum AppUpdateType {
  GENERAL
  FEATURE
  FIX
  PERFORMANCE
  SECURITY
}

enum DiscoveryInsightKind {
  TRENDING
  RISING
  COMMUNITY_PICK
}

enum ReviewStatus {
  PUBLISHED
  REMOVED
  FLAGGED
}

enum ReviewResolution {
  DISMISSED
  REMOVED
  NO_ACTION
}

model User {
  id            String                    @id @default(cuid())
  privyDid      String                    @unique
  email         String?
  username      String?                   @unique
  displayName   String?
  avatarUrl     String?
  role          UserRole                  @default(USER)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  profile       UserProfile?
  createdApps   App[]                     @relation("AppCreatedBy")
  reviews       Review[]
  reviewFlags   ReviewFlag[]              @relation("ReviewFlagReporter")
  reviewStrikes ReviewModerationStrike[]
  appLikes      AppLike[]
  libraryItems  AppLibraryItem[]
  searchEvents  SearchEvent[]
  appViews      AppView[]

  @@index([email])
}

model UserProfile {
  id               String  @id @default(cuid())
  userId           String  @unique
  bio              String?
  profileCompleted Boolean @default(false)
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id               String          @id @default(cuid())
  slug             String          @unique
  name             String          @unique
  sortOrder        Int
  apps             App[]
  editorialShelves EditorialShelf[]
}

model App {
  id               String              @id @default(cuid())
  slug             String              @unique
  name             String
  shortDescription String
  longDescription  String
  websiteUrl       String
  logoUrl          String
  verified         Boolean             @default(false)
  verifiedNote     String?
  verifiedUpdatedAt DateTime?
  agentAudience    AppAudience         @default(HUMAN)
  agentListingStatus AgentListingStatus @default(NOT_APPLICABLE)
  agentSummary     String?
  agentDocsUrl     String?
  agentIntegrationNotes String?
  communityPick    Boolean             @default(false)
  communityPickMonth String?
  communityPickReason Json?
  communityPickUpdatedAt DateTime?
  categoryId       String
  status           AppStatus           @default(DRAFT)
  createdByUserId  String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  publishedAt      DateTime?
  category         Category            @relation(fields: [categoryId], references: [id])
  createdBy        User                @relation("AppCreatedBy", fields: [createdByUserId], references: [id])
  tags             AppTag[]
  screenshots      AppScreenshot[]
  embedding        AppEmbedding?
  signals          AppSignal[]
  signalSnapshots  AppSignalSnapshot[]
  reviews          Review[]
  likes            AppLike[]
  libraryItems     AppLibraryItem[]
  views            AppView[]
  searchClicks     SearchClick[]
  editorialItems   EditorialShelfItem[]
  updates          AppUpdate[]
  agentCapabilities AgentCapability[]
  discoveryInsights DiscoveryInsightSnapshot[]

  @@index([categoryId, status])
  @@index([createdByUserId])
  @@index([status, publishedAt])
  @@index([agentAudience, agentListingStatus, status])
  @@index([communityPick, communityPickUpdatedAt])
}

model AgentCapability {
  id               String                 @id @default(cuid())
  appId            String
  name             String
  slug             String
  description      String
  capabilityType   String
  authType         AgentAuthType          @default(NONE)
  interfaceType    AgentInterfaceType     @default(HTTP_API)
  interactionMode  AgentInteractionMode   @default(READ_ONLY)
  endpointUrl      String?
  docsUrl          String?
  inputSchemaJson  Json?
  outputSchemaJson Json?
  safetyNotes      String?
  status           AgentCapabilityStatus  @default(ACTIVE)
  reliabilityScore Float?
  latencyP50Ms     Int?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  app              App                    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([appId, slug])
  @@index([appId, status])
  @@index([capabilityType, status])
  @@index([interfaceType, interactionMode, status])
}

model AgentRegistryEvaluationLog {
  id                     String   @id @default(cuid())
  query                  String
  normalizedQuery        String
  filtersJson            Json
  resultCount            Int
  candidateCount         Int
  matchedCapabilityCount Int
  topAppId               String?
  topCapabilityId        String?
  topCategorySlug        String?
  topCapabilityType      String?
  topReadinessBucket     String?
  topSimilarity          Float?
  topScore               Float?
  topQualityScore        Int?
  topMatchReason         String?
  excludedCandidatesJson Json
  blockingIssueCount     Int
  createdAt              DateTime @default(now())

  @@index([normalizedQuery, createdAt])
  @@index([topAppId, createdAt])
  @@index([topCategorySlug, createdAt])
  @@index([topCapabilityType, createdAt])
  @@index([topReadinessBucket, createdAt])
}

model AgentRegistryIntentTestRun {
  id                          String   @id @default(cuid())
  testCaseId                  String
  query                       String
  filtersJson                 Json
  expectedCategorySlug        String?
  expectedCapabilityTypesJson Json?
  expectedCapabilitySlugsJson Json?
  topMatchedAppId             String?
  topMatchedAppSlug           String?
  topMatchedCategorySlug      String?
  topMatchedCapabilityId      String?
  topMatchedCapabilitySlug    String?
  topMatchedCapabilityType    String?
  score                       Float?
  matchReason                 String?
  passed                      Boolean
  failureReason               String?
  ranAt                       DateTime @default(now())

  @@index([testCaseId, ranAt])
  @@index([passed, ranAt])
  @@index([expectedCategorySlug, ranAt])
}

model EditorialShelf {
  id          String                   @id @default(cuid())
  title       String
  slug        String                   @unique
  description String
  status      EditorialShelfStatus     @default(DRAFT)
  sortOrder   Int                      @default(0)
  visibility  EditorialShelfVisibility @default(HOME)
  pinned      Boolean                  @default(false)
  categoryId  String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  publishedAt DateTime?
  category    Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  items       EditorialShelfItem[]

  @@index([status, visibility, sortOrder])
  @@index([categoryId, status, visibility, sortOrder])
}

model EditorialShelfItem {
  id        String         @id @default(cuid())
  shelfId   String
  appId     String
  sortOrder Int
  createdAt DateTime       @default(now())
  shelf     EditorialShelf @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  app       App            @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([shelfId, appId])
  @@unique([shelfId, sortOrder])
  @@index([appId])
}

model AppTag {
  id    String @id @default(cuid())
  appId String
  tag   String
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId])
  @@unique([appId, tag])
}

model AppScreenshot {
  id        String @id @default(cuid())
  appId     String
  imageUrl  String
  sortOrder Int
  app       App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, sortOrder])
  @@unique([appId, sortOrder])
}

model AppEmbedding {
  id             String                     @id @default(cuid())
  appId          String                     @unique
  embedding      Unsupported("vector(1536)")
  embeddingModel String
  sourceText     String
  updatedAt      DateTime                   @updatedAt
  app            App                        @relation(fields: [appId], references: [id], onDelete: Cascade)
}

model AppSignal {
  id           String   @id @default(cuid())
  appId        String
  signalType   String
  signalKey    String
  numericValue Float?
  stringValue  String?
  jsonValue    Json?
  source       String
  observedAt   DateTime
  createdAt    DateTime @default(now())
  app          App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, signalType])
  @@index([signalKey, observedAt])
}

model AppSignalSnapshot {
  id           String   @id @default(cuid())
  appId        String
  category     String
  metric       String
  numericValue Float
  observedAt   DateTime
  app          App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, category, metric])
  @@index([category, metric, observedAt])
}

model AppUpdate {
  id           String        @id @default(cuid())
  appId        String
  versionLabel String
  title        String
  body         String
  publishedAt  DateTime
  type         AppUpdateType?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  app          App           @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, publishedAt])
}

model DiscoveryInsightSnapshot {
  id          String               @id @default(cuid())
  appId       String
  kind        DiscoveryInsightKind
  categorySlug String?
  score       Float
  rank        Int
  inputsJson  Json
  windowStart DateTime?
  windowEnd   DateTime?
  computedAt  DateTime             @default(now())
  app         App                  @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([kind, categorySlug, computedAt, rank])
  @@index([appId, kind, computedAt])
}

model Review {
  id            String       @id @default(cuid())
  appId         String
  userId        String
  rating        Int
  body          String
  status        ReviewStatus @default(PUBLISHED)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  removedAt     DateTime?
  removalReason String?
  app           App          @relation(fields: [appId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  flags         ReviewFlag[]
  strikes       ReviewModerationStrike[]

  @@unique([appId, userId])
  @@index([appId, status])
  @@index([userId, createdAt])
}

model ReviewFlag {
  id             String            @id @default(cuid())
  reviewId       String
  reporterUserId String
  reason         String
  createdAt      DateTime          @default(now())
  resolvedAt     DateTime?
  resolution     ReviewResolution?
  review         Review            @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporterUser   User              @relation("ReviewFlagReporter", fields: [reporterUserId], references: [id], onDelete: Cascade)

  @@index([reviewId, createdAt])
  @@index([reporterUserId])
  @@unique([reviewId, reporterUserId])
}

model ReviewModerationStrike {
  id           String   @id @default(cuid())
  userId       String
  reviewId     String
  strikeNumber Int
  createdAt    DateTime @default(now())
  expiresAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review       Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AppLike {
  id        String   @id @default(cuid())
  appId     String
  userId    String
  createdAt DateTime @default(now())
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([appId, userId])
}

model AppLibraryItem {
  id        String   @id @default(cuid())
  appId     String
  userId    String
  createdAt DateTime @default(now())
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([appId, userId])
}

model SearchEvent {
  id              String       @id @default(cuid())
  userId          String?
  query           String
  normalizedQuery String
  categoryHint    String?
  createdAt       DateTime     @default(now())
  user            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  searchClicks    SearchClick[]

  @@index([userId, createdAt])
  @@index([normalizedQuery])
}

model SearchClick {
  id            String      @id @default(cuid())
  searchEventId String
  appId         String
  position      Int
  createdAt     DateTime    @default(now())
  searchEvent   SearchEvent @relation(fields: [searchEventId], references: [id], onDelete: Cascade)
  app           App         @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([searchEventId, position])
  @@index([appId, createdAt])
}

model AppView {
  id        String   @id @default(cuid())
  appId     String
  userId    String?
  sessionId String?
  createdAt DateTime @default(now())
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([appId, createdAt])
  @@index([userId, createdAt])
}

model ConfigKV {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  updatedAt DateTime @updatedAt
}
